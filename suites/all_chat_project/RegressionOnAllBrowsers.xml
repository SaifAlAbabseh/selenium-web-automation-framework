<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="All Chat Regression Test Suite on All Browsers" parallel="tests" thread-count="3">
    <test name="Test on Chrome">
        <parameter name="browser" value="chrome" />
        <parameter name="mobileMode" value="true" />
        <parameter name="headlessMode" value="true" />
        <classes>
            <class name="runners.projects.all_chat_project.RegressionTest" />
        </classes>
    </test>

    <test name="Test on Edge">
        <parameter name="browser" value="edge" />
        <parameter name="mobileMode" value="false" />
        <parameter name="headlessMode" value="true" />
        <classes>
            <class name="runners.projects.all_chat_project.RegressionTest" />
        </classes>
    </test>

    <test name="Test on Firefox">
        <parameter name="browser" value="firefox" />
        <parameter name="mobileMode" value="true" />
        <parameter name="headlessMode" value="true" />
        <classes>
            <class name="runners.projects.all_chat_project.RegressionTest" />
        </classes>
    </test>
</suite>